{
  "name": "daily-quoter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c yellow,cyan \"bun run dev:api\" \"bun run dev:web\"",
    "dev:api": "bun --watch src/server.ts",
    "dev:web": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "bun run build && bun run src/server.ts",
    "serve": "bun run src/server.ts",
    "test": "bun run test:unit && bun run test:e2e",
    "test:unit": "bun test tests/unit",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.24",
    "bun-types": "^1.3.9",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^6.4.1"
  }
}
